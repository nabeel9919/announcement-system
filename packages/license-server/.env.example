DATABASE_URL="postgresql://user:password@localhost:5432/announcement_licenses"
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# CHANGE THESE IN PRODUCTION
LICENSE_HMAC_SECRET=your-very-long-random-secret-here
JWT_SECRET=your-jwt-secret-here

# Admin portal login
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-admin-password

# Google TTS (optional, for premium voices)
GOOGLE_TTS_API_KEY=

# Stripe (optional, for automated billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS — set to your web portal domain in production
CORS_ORIGIN=http://localhost:3000
