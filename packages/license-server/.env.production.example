# ── Database ──────────────────────────────────────────────────────────────────
# Railway/Render automatically sets DATABASE_URL when you add a PostgreSQL addon.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/announcement_licenses

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# ── Security — generate with: openssl rand -hex 32 ────────────────────────────
LICENSE_HMAC_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX

# ── Admin login for web portal ────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=STRONG_PASSWORD_HERE

# ── Google TTS (optional) ─────────────────────────────────────────────────────
GOOGLE_TTS_API_KEY=

# ── Africa's Talking SMS ──────────────────────────────────────────────────────
# Sandbox (testing): username=sandbox, any key
# Live:              username=YOUR_APP_NAME from africastalking.com
AFRICASTALKING_API_KEY=YOUR_LIVE_API_KEY
AFRICASTALKING_USERNAME=YOUR_APP_NAME

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Vercel web-portal URL in production
CORS_ORIGIN=https://your-portal.vercel.app
