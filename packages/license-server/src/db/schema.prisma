// Prisma schema for the license server PostgreSQL database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id               String         @id @default(cuid())
  organizationName String
  contactEmail     String         @unique
  contactPhone     String?
  country          String         @default("TZ")
  city             String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  licenses         License[]
  subscriptions    Subscription[]
  invoices         Invoice[]
}

model License {
  id               String    @id @default(cuid())
  /** Normalized 20-char key without dashes */
  key              String    @unique
  /** Formatted key with dashes for display */
  formattedKey     String    @unique
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id])
  tier             Tier      @default(STARTER)
  maxWindows       Int       @default(4)
  maxSites         Int       @default(1)
  features         String[]
  issuedAt         DateTime  @default(now())
  expiresAt        DateTime
  /** Machine fingerprint — set on first activation */
  machineId        String?
  isRevoked        Boolean   @default(false)
  revokedAt        DateTime?
  revokedReason    String?
  lastValidatedAt  DateTime?
  activatedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Subscription {
  id                  String             @id @default(cuid())
  clientId            String
  client              Client             @relation(fields: [clientId], references: [id])
  planId              String
  plan                PricingPlan        @relation(fields: [planId], references: [id])
  status              SubscriptionStatus @default(TRIALING)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  trialEndsAt         DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  canceledAt          DateTime?
  stripeSubscriptionId String?           @unique
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model PricingPlan {
  id                   String        @id @default(cuid())
  name                 String
  /** Price in full currency units (e.g. 30000 for 30,000 TZS) */
  price                Int
  currency             String        @default("TZS")
  interval             BillingInterval @default(MONTHLY)
  yearlyDiscountPercent Int?
  features             String[]
  maxWindows           Int
  maxSites             Int
  isActive             Boolean       @default(true)
  isHighlighted        Boolean       @default(false)
  sortOrder            Int           @default(0)
  stripePriceId        String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  subscriptions        Subscription[]
}

model Invoice {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  amount      Int           // in full currency units
  currency    String        @default("TZS")
  status      InvoiceStatus @default(OPEN)
  issuedAt    DateTime      @default(now())
  dueAt       DateTime
  paidAt      DateTime?
  description String
  stripeInvoiceId String?   @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum Tier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}
